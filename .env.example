# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Quotetion — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in values:
#   cp .env.example .env
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Optional API key for demonstration purposes.
# The application works WITHOUT this key.
# If not set, a warning is logged but everything functions normally.
MOTIVATION_API_KEY=your-optional-api-key-here

# Backend URL for the frontend to connect to.
# Default: http://localhost:8000 (for local development)
# Change this to your Render URL when deploying the frontend.
BACKEND_URL=http://localhost:8000
